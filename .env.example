# Copy to .env and fill in. Never commit .env.
#
# Nakama database address (NOT a postgresql:// URL). Format:
#   username:password@host:port/database?query_params
#
# Neon example (use your branch’s connection details; rotate credentials if exposed):
# DATABASE_ADDRESS=neondb_owner:YOUR_PASSWORD@ep-xxxx.region.aws.neon.tech:5432/neondb?sslmode=require
#
# Local docker-compose postgres (default in docker-compose.yml):
# DATABASE_ADDRESS=postgres:password@postgres:5432/nakama?sslmode=disable

DATABASE_ADDRESS=

# Must match the game client VITE_NAKAMA_SERVER_KEY
NAKAMA_SERVER_KEY=

# Nakama console (http://host:7351)
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=
